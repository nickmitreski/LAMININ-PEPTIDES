# Copy to .env.local (gitignored) and replace placeholders.

# -----------------------------------------------------------------------------
# Supabase — used by the Vite app (order refs, mappings, Edge Functions invoke)
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the "anon" / "public" API key (JWT eyJ...) or publishable key (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# -----------------------------------------------------------------------------
# Supabase CLI — NOT read by Vite; use in your terminal / shell profile only
# -----------------------------------------------------------------------------
# Easiest:  npx supabase login
# Or one line in ~/.zshrc (ASCII double quotes only — no ‘smart quotes’):
#   export SUPABASE_ACCESS_TOKEN="sbp_xxxxxxxx"
# Link project:  npx supabase link --project-ref your-project-ref
# DB password: only for psql / direct connection — never commit:
#   postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Admin UI (/admin/*)
# -----------------------------------------------------------------------------
# Comma-separated emails — WARNING: values are embedded in the client bundle (readable by anyone).
# Prefer Supabase app_metadata + RLS for production admin gates.
# VITE_ADMIN_EMAIL_ALLOWLIST=you@example.com,other@example.com

# -----------------------------------------------------------------------------
# Partner protein store — checkout bridge (CheckoutPayload)
# -----------------------------------------------------------------------------
# VITE_PROTEIN_STORE_URL=https://your-protein-store.com
# Optional Bearer for partner API — WARNING: exposed in the browser bundle; use a server/Edge proxy if secret.
# VITE_PROTEIN_STORE_API_KEY=optional_bearer_token

# -----------------------------------------------------------------------------
# Checkout UX
# -----------------------------------------------------------------------------
# VITE_CHECKOUT_SOFT_LAUNCH=true
# VITE_CHECKOUT_INIT_SECRET=optional_shared_secret_with_edge_function
# VITE_DEV_MOCK_SECURE_CHECKOUT=true
# Min ms the secure modal stays on “Encrypting…” (default 3000)
# VITE_CHECKOUT_ENCRYPT_MIN_MS=3000
# Min ms before “Continue” is enabled on the sent step (default 5000)
# VITE_CHECKOUT_SENT_CONTINUE_MIN_MS=5000
# If true, this site may redirect to payment_portal_url. Default false: partner opens pay UI via API.
# VITE_OPEN_PAYMENT_URL_ON_THIS_SITE=true
# CoreForge embedded checkout: HTTPS origin of the pay app (e.g. https://pay.coreforge.com). Iframe src = origin/embed/pay/{payment_id}
# VITE_COREFORGE_PAY_ORIGIN=https://pay.coreforge.com
# White-label checkout copy (affiliates / referrals)
# VITE_CHECKOUT_BRAND_NAME=Secure checkout
# VITE_CHECKOUT_PARTNER_LABEL=payment provider
# Match Edge secret CHECKOUT_DELIVERY_BRAND (email/SMS “from …” copy on storefront modal)
# VITE_CHECKOUT_DELIVERY_BRAND=LAMININ
# Match PAYMENT_LINK_CURRENCY / Square (modal amount label); default in app is AUD + en-AU formatting
# VITE_CHECKOUT_DISPLAY_CURRENCY=AUD
# GST rate on cart subtotal at checkout (0–1). Default 0.1. Set 0 if subtotal is already tax-inclusive.
# VITE_CHECKOUT_GST_RATE=0.1
# JSON-LD Product offer currency (default AUD)
# VITE_LISTING_PRICE_CURRENCY=AUD

# -----------------------------------------------------------------------------
# Supabase Edge secrets (Dashboard → Edge Functions → Secrets; not Vite)
# -----------------------------------------------------------------------------
# PAYMENT_LINK_CREATE_URL=https://PARTNER_REF.supabase.co/functions/v1/create-payment-link
# PAYMENT_LINK_BEARER=shared_secret_with_partner
# Demo only: returns OTP in API + shows in secure modal — disable before production
# RETURN_CHECKOUT_OTP_IN_RESPONSE=true
# CoreForge: request embeddable checkout URL (payment_url should be …/embed/pay/{id})
# PAYMENT_LINK_EMBED=true
# SMS/email link: "parent" = https://<LAMIN>/pay?pid=…&ref=… ; "direct" = full CoreForge URL in message
# COREFORGE_SMS_PAYMENT_LINK_MODE=parent
# LAMIN_PUBLIC_SITE_URL=https://your-store.vercel.app
# Optional overrides (defaults mention CoreForge Payments)
# COREFORGE_PAYMENTS_DISCLOSURE_SMS= Payment is processed through CoreForge Payments.
# COREFORGE_PAYMENTS_DISCLOSURE_EMAIL=
# Optional override; function defaults metadata.source to lamin for partner strict mode:
# PAYMENT_LINK_METADATA_SOURCE=lamin

# --- COREFORGE async flow (payment site creates pay URL; LAMIN SMS after webhook) ---
# ASYNC_COREFORGE_PAYMENT_FLOW=true
# COREFORGE_INGEST_URL=https://YOUR-PAY-SITE.supabase.co/functions/v1/lamin-checkout-ingest
# COREFORGE_INGEST_BEARER=long_random_shared_secret
# PARTNER_PAYMENT_READY_SECRET=same_or_different_secret_for_webhook_to_LAMIN
# MOCK_SMS_DELIVERY=true
# When MOCK_SMS_DELIVERY=true, partner-payment-ready logs SMS body only (no Twilio call).
# TWILIO_USE_WHATSAPP=true
# TWILIO_FROM_NUMBER=whatsapp:+14155238886
# (Sandbox: use Twilio’s sandbox From; unset TWILIO_MESSAGING_SERVICE_SID. Auth = API Key “Auth Token”, not OAuth client secret.)

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5173
# `npm run sitemap` uses VITE_APP_URL; loopback URLs fall back to production in public/sitemap.xml.
# Set to your real domain for CI, or use:  SITEMAP_ALLOW_LOCAL=1 npm run sitemap  for localhost locs.

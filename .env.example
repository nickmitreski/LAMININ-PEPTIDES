# Supabase (order references + product mappings)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Admin UI (/admin/*): optional comma-separated allowlist (transitional).
# Prefer marking users in Supabase Auth App Metadata: { "admin": true } (see supabase/admin_auth_setup.sql).
# VITE_ADMIN_EMAIL_ALLOWLIST=you@example.com,other@example.com

# Partner protein store — checkout bridge
# POST body: JSON from src/services/proteinCheckout.ts (CheckoutPayload)
# Default path: /api/peptide-bridge/checkout
VITE_PROTEIN_STORE_URL=https://your-protein-store.com
VITE_PROTEIN_STORE_API_KEY=your_api_key_optional

# When true: no redirect to partner payment — order is saved and user sees “opening soon”
# messaging on checkout + confirmation (uses contact details for follow-up).
# VITE_CHECKOUT_SOFT_LAUNCH=true
#
# Run `npm test` to verify checkout redirect logic (soft launch, missing URL, API fallbacks, CFG lines).

# App
VITE_APP_URL=http://localhost:5173

# Copy to .env.local (gitignored) and replace placeholders.

# -----------------------------------------------------------------------------
# Supabase — used by the Vite app (order refs, mappings, Edge Functions invoke)
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the "anon" / "public" API key (JWT eyJ...) or publishable key (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# -----------------------------------------------------------------------------
# Supabase CLI — NOT read by Vite; use in your terminal / shell profile only
# -----------------------------------------------------------------------------
# Easiest:  npx supabase login
# Or one line in ~/.zshrc (ASCII double quotes only — no ‘smart quotes’):
#   export SUPABASE_ACCESS_TOKEN="sbp_xxxxxxxx"
# Link project:  npx supabase link --project-ref your-project-ref
# DB password: only for psql / direct connection — never commit:
#   postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Admin UI (/admin/*)
# -----------------------------------------------------------------------------
# VITE_ADMIN_EMAIL_ALLOWLIST=you@example.com,other@example.com

# -----------------------------------------------------------------------------
# Partner protein store — checkout bridge (CheckoutPayload)
# -----------------------------------------------------------------------------
# VITE_PROTEIN_STORE_URL=https://your-protein-store.com
# VITE_PROTEIN_STORE_API_KEY=optional_bearer_token

# -----------------------------------------------------------------------------
# Checkout UX
# -----------------------------------------------------------------------------
# VITE_CHECKOUT_SOFT_LAUNCH=true
# VITE_CHECKOUT_INIT_SECRET=optional_shared_secret_with_edge_function
# VITE_DEV_MOCK_SECURE_CHECKOUT=true
# Min ms the secure modal stays on “encrypting” before the next step (default 5000)
# VITE_CHECKOUT_ENCRYPT_MIN_MS=5000
# If true, this site may redirect to payment_portal_url. Default false: partner opens pay UI via API.
# VITE_OPEN_PAYMENT_URL_ON_THIS_SITE=true
# White-label checkout copy (affiliates / referrals)
# VITE_CHECKOUT_BRAND_NAME=Secure checkout
# VITE_CHECKOUT_PARTNER_LABEL=payment provider
# Match Edge secret CHECKOUT_DELIVERY_BRAND (email/SMS “from …” copy on storefront modal)
# VITE_CHECKOUT_DELIVERY_BRAND=LAMININ
# Match PAYMENT_LINK_CURRENCY / Square (modal amount label)
# VITE_CHECKOUT_DISPLAY_CURRENCY=USD

# -----------------------------------------------------------------------------
# Supabase Edge secrets (Dashboard → Edge Functions → Secrets; not Vite)
# -----------------------------------------------------------------------------
# PAYMENT_LINK_CREATE_URL=https://PARTNER_REF.supabase.co/functions/v1/create-payment-link
# PAYMENT_LINK_BEARER=shared_secret_with_partner
# Optional override; function defaults metadata.source to lamin for partner strict mode:
# PAYMENT_LINK_METADATA_SOURCE=lamin

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5173
